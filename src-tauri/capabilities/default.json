{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for PDF Reader",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-read-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**/*" }]
    },
    "dialog:default",
    "dialog:allow-open",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "shell:allow-open"
  ]
}
